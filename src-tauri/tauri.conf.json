{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shakh",
  "version": "0.1.0",
  "identifier": "app.shakh.desktop",
  "build": {
    "frontendDist": "https://shakh.vercel.app/login"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Shakh",
        "width": 1280,
        "height": 840,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
